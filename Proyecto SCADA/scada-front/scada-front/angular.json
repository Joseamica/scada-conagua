{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false
  },

  "projects": {
    "scada-demo": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",

      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "server": "src/main.server.ts",
            "tsConfig": "tsconfig.app.json",
            "polyfills": [
            "zone.js" 
            ],

            "assets": [
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets/"
              },
              {
                "glob": "**/*",
                "input": "src/favicon",
                "output": "/favicon/"
              }
            ],

            "styles": [
              "src/styles.css"
            ],

            "scripts": [
              "node_modules/leaflet/dist/leaflet.js"
            ]
          },

          "configurations": {
            "development": {
              "sourceMap": true
            },
            "production": {
              "outputHashing": "all"
            }
          },

          "defaultConfiguration": "production"
        },

        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "development": {
              "buildTarget": "scada-demo:build:development",
              "proxyConfig": "proxy.conf.json",
              "allowedHosts": true
            },
            "production": {
              "buildTarget": "scada-demo:build:production"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
