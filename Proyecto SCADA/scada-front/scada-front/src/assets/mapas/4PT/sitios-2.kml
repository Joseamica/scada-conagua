	<Folder>
		<name>Sitios_Chalco.kmz</name>
		<Placemark>
			<name>CAUDAL 01</name>
			<description>
&lt;div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; max-width: 700px; margin: 0; padding: 0; background: #ffffff; border: 1px solid #d0d0d0; box-shadow: 0 2px 8px rgba(0,0,0,0.06);"&gt;

    &lt;!-- ENCABEZADO --&gt;
    &lt;div style="background: linear-gradient(135deg, #7ED321 0%, #5CB800 100%); color: white; padding: 18px 24px; border-bottom: 3px solid #95E044; text-align: center;"&gt;
        &lt;h2 style="margin: 0; font-size: 19px; font-weight: 600; letter-spacing: 0.3px; line-height: 1.3;"&gt;CAUDAL 01&lt;/h2&gt;
    &lt;/div&gt;

    &lt;!-- TABLA DE INFORMACIÓN TÉCNICA --&gt;
    &lt;div style="background: #f8f9fa; padding: 20px 24px;"&gt;
        &lt;h3 style="color: #7ED321; margin: 0 0 14px 0; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #7ED321; padding-bottom: 8px;"&gt;
            Información Técnica
        &lt;/h3&gt;

        &lt;table style="width: 100%; border-collapse: collapse; font-size: 13px; background: white; border: 1px solid #e0e0e0;"&gt;
            &lt;tr style="background: #f5f5f5; border-bottom: 1px solid #d0d0d0;"&gt;
                &lt;td style="padding: 12px 16px; font-weight: 600; color: #212121; width: 35%; border-right: 1px solid #e0e0e0;"&gt;Coordenadas GPS&lt;/td&gt;
                &lt;td style="padding: 12px 16px; color: #212121; font-family: 'Courier New', monospace; font-size: 12px; text-align: center;"&gt;19.259146, -98.900379&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr style="background: #ffffff; border-bottom: 1px solid #d0d0d0;"&gt;
                &lt;td style="padding: 12px 16px; font-weight: 600; color: #212121; border-right: 1px solid #e0e0e0;"&gt;Municipio&lt;/td&gt;
                &lt;td style="padding: 12px 16px; color: #212121; text-align: center;"&gt;Chalco&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr style="background: #f5f5f5; border-bottom: 1px solid #d0d0d0;"&gt;
                &lt;td style="padding: 12px 16px; font-weight: 600; color: #212121; border-right: 1px solid #e0e0e0;"&gt;Tipo de Instalación&lt;/td&gt;
                &lt;td style="padding: 12px 16px; color: #212121; text-align: center;"&gt;Caudal&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr style="background: #ffffff; border-bottom: 1px solid #d0d0d0;"&gt;
                &lt;td style="padding: 12px 16px; font-weight: 600; color: #212121; border-right: 1px solid #e0e0e0;"&gt;Estado Operativo&lt;/td&gt;
                &lt;td style="padding: 12px 16px; text-align: center;"&gt;
                    &lt;span style="display: inline-block; padding: 7px 20px; background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%); color: white; border-radius: 16px; font-weight: 600; font-size: 11px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); letter-spacing: 0.4px;"&gt;
                        ✓ OPERATIVO
                    &lt;/span&gt;
                &lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr style="background: #f5f5f5; border-bottom: 1px solid #d0d0d0;"&gt;
                &lt;td style="padding: 12px 16px; font-weight: 600; color: #212121; border-right: 1px solid #e0e0e0;"&gt;Nivel de Señal&lt;/td&gt;
                &lt;td style="padding: 12px 16px; text-align: center;"&gt;
                    &lt;div style="margin-bottom: 4px;"&gt;
                        &lt;table style="display: inline-table; border-collapse: collapse; height: 20px; vertical-align: middle;"&gt;&lt;tr&gt;&lt;td style="padding: 0 1px; vertical-align: bottom;"&gt;&lt;div style="width: 6px; height: 4px; background: #2E7D32; border-radius: 1px;"&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style="padding: 0 1px; vertical-align: bottom;"&gt;&lt;div style="width: 6px; height: 8px; background: #2E7D32; border-radius: 1px;"&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style="padding: 0 1px; vertical-align: bottom;"&gt;&lt;div style="width: 6px; height: 12px; background: #2E7D32; border-radius: 1px;"&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style="padding: 0 1px; vertical-align: bottom;"&gt;&lt;div style="width: 6px; height: 16px; background: #2E7D32; border-radius: 1px;"&gt;&lt;/div&gt;&lt;/td&gt;&lt;td style="padding: 0 1px; vertical-align: bottom;"&gt;&lt;div style="width: 6px; height: 20px; background: #2E7D32; border-radius: 1px;"&gt;&lt;/div&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;
                    &lt;/div&gt;
                    &lt;div style="color: #5f6368; font-weight: 600; font-size: 12px;"&gt;
                        Señal óptima
                    &lt;/div&gt;
                &lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr style="background: #ffffff;"&gt;
                &lt;td style="padding: 12px 16px; font-weight: 600; color: #212121; border-right: 1px solid #e0e0e0;"&gt;Carrier&lt;/td&gt;
                &lt;td style="padding: 12px 16px; color: #212121; text-align: center;"&gt;Telcel&lt;/td&gt;
            &lt;/tr&gt;
        &lt;/table&gt;
    &lt;/div&gt;

    &lt;!-- OBSERVACIONES TÉCNICAS --&gt;
    &lt;div style="background: #f8f9fa; padding: 20px 24px; border-top: 1px solid #e0e0e0;"&gt;
        &lt;h3 style="color: #7ED321; margin: 0 0 14px 0; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #7ED321; padding-bottom: 8px;"&gt;
            Observaciones Técnicas
        &lt;/h3&gt;
        &lt;div style="background: white; padding: 16px 18px; border-left: 3px solid #7ED321; color: #212121; line-height: 1.7; font-size: 13px;"&gt;
            Sin descripción técnica disponible.
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- FOOTER --&gt;
    &lt;div style="background: linear-gradient(135deg, #7ED321 0%, #5CB800 100%); color: white; text-align: center; padding: 12px; font-size: 11px; font-weight: 500; letter-spacing: 0.6px;"&gt;
        4PTelecom - CONAGUA
    &lt;/div&gt;

&lt;/div&gt;
</description>
