                &lt;!-- IMAGEN CENTRAL --&gt;
                &lt;td style="text-align: center; vertical-align: middle; padding: 10px;"&gt;
                    &lt;div id="carousel-images-wrapper" style="min-height: 300px;"&gt;

                        &lt;div id="slide-0" class="carousel-slide" style="display: block; text-align: center;"&gt;
