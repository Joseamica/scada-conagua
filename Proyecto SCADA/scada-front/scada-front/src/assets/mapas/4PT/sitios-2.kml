        &lt;/h3&gt;

        &lt;!-- TÍTULO DINÁMICO --&gt;
        &lt;div id="carousel-title" style="text-align: center; font-size: 15px; font-weight: 600; color: #212121; margin-bottom: 16px; padding: 10px 16px; background: #f8f9fa; border-radius: 6px; border-left: 4px solid #7ED321;"&gt;
            Foto Sitio Actual
        &lt;/div&gt;

        &lt;!-- LAYOUT: FLECHA - IMAGEN - FLECHA (usando tabla) --&gt;
        &lt;table style="width: 100%; border-collapse: collapse; table-layout: fixed;"&gt;
            &lt;tr&gt;
                &lt;!-- FLECHA IZQUIERDA --&gt;
                &lt;td style="width: 50px; text-align: center; vertical-align: middle; padding: 5px;"&gt;
                    &lt;div onclick="cambiarSlide(-1)" style="width: 40px; height: 40px; background: linear-gradient(135deg, #7ED321 0%, #5CB800 100%); border-radius: 50%; color: white; font-size: 18px; font-weight: bold; cursor: pointer; box-shadow: 0 3px 8px rgba(0,0,0,0.2); display: inline-block; line-height: 40px; text-align: center;"&gt;
                        &amp;#10094;
                    &lt;/div&gt;
                &lt;/td&gt;
                
                &lt;!-- IMAGEN CENTRAL --&gt;
                &lt;td style="text-align: center; vertical-align: middle; padding: 10px;"&gt;
