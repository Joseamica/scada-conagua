    &lt;!-- CARRUSEL DE IMÁGENES --&gt;
    &lt;div style="background: #ffffff; padding: 20px 24px; border-top: 1px solid #e0e0e0;"&gt;
        &lt;h3 style="color: #7ED321; margin: 0 0 16px 0; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #7ED321; padding-bottom: 8px;"&gt;
            Registro Fotográfico
        &lt;/h3&gt;

        &lt;!-- TÍTULO DINÁMICO --&gt;
        &lt;div id="carousel-title" style="text-align: center; font-size: 15px; font-weight: 600; color: #212121; margin-bottom: 16px; padding: 10px 16px; background: #f8f9fa; border-radius: 6px; border-left: 4px solid #7ED321;"&gt;
