        &lt;!-- CONTADOR --&gt;
        &lt;div style="text-align: center; margin-top: 14px; font-size: 13px; color: #5f6368; font-weight: 500;"&gt;
            Imagen &lt;span id="slide-current"&gt;1&lt;/span&gt; de 4
        &lt;/div&gt;

        &lt;!-- THUMBNAILS --&gt;
        &lt;div style="text-align: center; margin-top: 16px;"&gt;

            &lt;img id="thumb-0" src="files/pozo_334_jardines_casa_nueva_1_foto_actual.jpg" alt="Foto Sitio Actual" onclick="irASlide(0)" style="width: 70px; height: 52px; object-fit: cover; border: 2px solid #7ED321; border-radius: 4px; cursor: pointer; opacity: 1; margin: 0 5px; vertical-align: middle;"&gt;

            &lt;img id="thumb-1" src="files/pozo_334_jardines_casa_nueva_1_plano_actual.jpg" alt="Plano Sitio Actual" onclick="irASlide(1)" style="width: 70px; height: 52px; object-fit: cover; border: 2px solid #d0d0d0; border-radius: 4px; cursor: pointer; opacity: 0.5; margin: 0 5px; vertical-align: middle;"&gt;

            &lt;img id="thumb-2" src="files/pozo_334_jardines_casa_nueva_1_foto_final.jpg" alt="Foto Sitio Final Intervenido" onclick="irASlide(2)" style="width: 70px; height: 52px; object-fit: cover; border: 2px solid #d0d0d0; border-radius: 4px; cursor: pointer; opacity: 0.5; margin: 0 5px; vertical-align: middle;"&gt;

            &lt;img id="thumb-3" src="files/pozo_334_jardines_casa_nueva_1_plano_final.jpg" alt="Plano Final" onclick="irASlide(3)" style="width: 70px; height: 52px; object-fit: cover; border: 2px solid #d0d0d0; border-radius: 4px; cursor: pointer; opacity: 0.5; margin: 0 5px; vertical-align: middle;"&gt;

        &lt;/div&gt;

        &lt;!-- JAVASCRIPT - Simple y compatible --&gt;
        &lt;script&gt;
            var slideActual = 0;
            var totalSlides = 4;
            var titulos = ["Foto Sitio Actual", "Plano Sitio Actual", "Foto Sitio Final Intervenido", "Plano Final"];
            
            function cambiarSlide(direccion) {
                // Ocultar slide actual
                document.getElementById('slide-' + slideActual).style.display = 'none';
                document.getElementById('thumb-' + slideActual).style.opacity = '0.5';
                document.getElementById('thumb-' + slideActual).style.borderColor = '#d0d0d0';
                
                // Calcular nuevo índice
                slideActual = slideActual + direccion;
                if (slideActual &gt;= totalSlides) slideActual = 0;
                if (slideActual &lt; 0) slideActual = totalSlides - 1;
                
                // Mostrar nuevo slide
                mostrarSlide();
            }
            
            function irASlide(index) {
                // Ocultar slide actual
                document.getElementById('slide-' + slideActual).style.display = 'none';
                document.getElementById('thumb-' + slideActual).style.opacity = '0.5';
                document.getElementById('thumb-' + slideActual).style.borderColor = '#d0d0d0';
                
                slideActual = index;
                mostrarSlide();
            }
            
            function mostrarSlide() {
                // Mostrar slide
                document.getElementById('slide-' + slideActual).style.display = 'block';
                
                // Actualizar thumbnail
                document.getElementById('thumb-' + slideActual).style.opacity = '1';
                document.getElementById('thumb-' + slideActual).style.borderColor = '#7ED321';
                
                // Actualizar título
                document.getElementById('carousel-title').innerHTML = titulos[slideActual];
                
                // Actualizar contador
                document.getElementById('slide-current').innerHTML = (slideActual + 1);
            }
        &lt;/script&gt;
    &lt;/div&gt;

