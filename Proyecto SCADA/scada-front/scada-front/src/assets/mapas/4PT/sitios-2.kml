        &lt;script&gt;
            var slideActual = 0;
            var totalSlides = 3;
            var titulos = ["Foto Sitio Actual", "Plano Sitio Actual", "Plano Final"];
            
            function cambiarSlide(direccion) {
                // Ocultar slide actual
                document.getElementById('slide-' + slideActual).style.display = 'none';
                document.getElementById('thumb-' + slideActual).style.opacity = '0.5';
                document.getElementById('thumb-' + slideActual).style.borderColor = '#d0d0d0';
                
                // Calcular nuevo índice
                slideActual = slideActual + direccion;
                if (slideActual &gt;= totalSlides) slideActual = 0;
                if (slideActual &lt; 0) slideActual = totalSlides - 1;
                
                // Mostrar nuevo slide
                mostrarSlide();
            }
            
            function irASlide(index) {
                // Ocultar slide actual
                document.getElementById('slide-' + slideActual).style.display = 'none';
                document.getElementById('thumb-' + slideActual).style.opacity = '0.5';
                document.getElementById('thumb-' + slideActual).style.borderColor = '#d0d0d0';
                
                slideActual = index;
                mostrarSlide();
            }
            
            function mostrarSlide() {
                // Mostrar slide
                document.getElementById('slide-' + slideActual).style.display = 'block';
                
                // Actualizar thumbnail
                document.getElementById('thumb-' + slideActual).style.opacity = '1';
                document.getElementById('thumb-' + slideActual).style.borderColor = '#7ED321';
                
                // Actualizar título
                document.getElementById('carousel-title').innerHTML = titulos[slideActual];
                
                // Actualizar contador
                document.getElementById('slide-current').innerHTML = (slideActual + 1);
